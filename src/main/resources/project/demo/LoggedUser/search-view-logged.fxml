<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>
<?import java.lang.String?>
<?import javafx.collections.FXCollections?>

<?import javafx.scene.shape.SVGPath?>
<?import javafx.scene.shape.Circle?>
<ScrollPane fitToWidth="true" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="project.demo.SearchController" stylesheets="@../style.css">

    <VBox spacing="0" styleClass="search-page">

        <!-- NAVBAR STRUTTURA ORIGINALE -->
        <HBox styleClass="navbar" alignment="CENTER_LEFT" prefHeight="64">
            <padding><Insets left="60" right="60"/></padding>
            <HBox alignment="CENTER_LEFT" onMouseClicked="#handleGoToHome" style="-fx-cursor: hand;">
                <Text text="The" style="-fx-font-family: 'Playfair Display'; -fx-font-size: 26; -fx-font-weight: bold; -fx-fill: white;"/>
                <Text text="Knife" style="-fx-font-family: 'Playfair Display'; -fx-font-size: 26; -fx-font-weight: bold; -fx-fill: #74C69D;"/>
            </HBox>

            <Region HBox.hgrow="ALWAYS" />

            <Button  styleClass="user-avatar-btn">
                <graphic>
                    <StackPane onMouseClicked="#handleGoToProfile" style="-fx-cursor: hand;">
                        <Circle radius="20" fill="white" stroke="#B7E4C7" strokeWidth="1" />

                        <SVGPath content="M12,2C14.2,2 16,3.8 16,6C16,8.2 14.2,10 12,10C9.8,10 8,8.2 8,6C8,3.8 9.8,2 12,2M12,12C7.6,12 4,13.8 4,16V18H20V16C20,13.8 16.4,12 12,12Z"
                                 fill="#4A6B57" scaleX="1.1" scaleY="1.1"/>
                    </StackPane>
                </graphic>
            </Button>
        </HBox>

        <!-- SEZIONE BARRA DI RICERCA SUPERIORE (Ripristinato l'enorme capsula bianca) -->
        <HBox styleClass="page-search-section" alignment="CENTER">
            <padding><Insets top="22" bottom="22" left="60" right="60"/></padding>
            <children>
                <HBox styleClass="page-search-bar" alignment="CENTER_LEFT" maxWidth="560" HBox.hgrow="ALWAYS">
                    <children>
                        <Label text="🔍" styleClass="page-search-icon"/>
                        <TextField fx:id="searchInlineField" promptText="Cerca ristoranti, cucina, città..." styleClass="page-search-input" HBox.hgrow="ALWAYS" onAction="#OnCercaPremuto"/>
                        <Button text="Cerca" onAction="#OnCercaPremuto" styleClass="btn-search-page"/>
                    </children>
                </HBox>
            </children>
        </HBox>

        <!-- CONTENUTO PRINCIPALE -->
        <HBox spacing="30" alignment="TOP_CENTER">
            <padding><Insets top="10" bottom="60" left="60" right="60"/></padding>
            <children>

                <!-- PANNELLO FILTRI LATERALE SINISTRO (Eredita lo stile nativo con angoli tondi e ombre) -->
                <VBox spacing="20" prefWidth="280" minWidth="280" styleClass="sidebar-card">
                    <padding><Insets top="30" right="25" bottom="30" left="25"/></padding>
                    <children>
                        <Label text="Filtri Avanzati" styleClass="field-label" style="-fx-font-weight: bold; -fx-font-size: 14;"/>

                        <VBox spacing="5">
                            <Label text="Città" styleClass="field-label"/>
                            <TextField fx:id="filterCitta" promptText="Es. Milano" styleClass="home-text-field"/>
                        </VBox>

                        <VBox spacing="5">
                            <Label text="Prezzo Massimo (€)" styleClass="field-label"/>
                            <TextField fx:id="filterPrezzo" promptText="Es. 50" styleClass="home-text-field"/>
                        </VBox>

                        <VBox spacing="5">
                            <Label text="Valutazione Minima" styleClass="field-label"/>
                            <ComboBox fx:id="filterStelle" promptText="Tutti" maxWidth="Infinity" styleClass="home-text-field" />
                        </VBox>

                        <VBox spacing="10">
                            <Button text="Applica Filtri" onAction="#onAggiornaFiltriPremuto" styleClass="btn-primary" maxWidth="Infinity"/>
                            <Button text="Resetta Filtri 🔄" onAction="#onResetFiltriPremuto" style="-fx-background-color: transparent; -fx-text-fill: #EF4444; -fx-font-weight: bold; -fx-cursor: hand;" maxWidth="Infinity"/>
                        </VBox>
                    </children>
                </VBox>

                <!-- COLONNA RISULTATI DESTRA -->
                <VBox spacing="15" HBox.hgrow="ALWAYS" maxWidth="800">
                    <children>

                        <HBox alignment="CENTER_LEFT" styleClass="results-header">
                            <padding><Insets bottom="10"/></padding>
                            <children>
                                <Label text="Ristoranti Trovati" style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #1B4332;"/>
                                <Region HBox.hgrow="ALWAYS" />

                                <!-- ATTIVAZIONE ORDINAMENTO IMMEDIATO -->
                                <ComboBox fx:id="filterOrdine" promptText="Ordina per..." prefWidth="200" styleClass="home-text-field" onAction="#onAggiornaFiltriPremuto">
                                    <items>
                                        <FXCollections fx:factory="observableArrayList">
                                            <String fx:value="Predefinito" />
                                            <String fx:value="Prezzo: Più economico" />
                                            <String fx:value="Prezzo: Più caro" />
                                            <String fx:value="Nome: A-Z" />
                                        </FXCollections>
                                    </items>
                                </ComboBox>
                            </children>
                        </HBox>

                        <!-- Box per le card dinamiche generate dal codice Java -->
                        <VBox fx:id="containerRisultati" spacing="15" HBox.hgrow="ALWAYS" />

                        <!-- Paginazione delle card -->
                        <HBox fx:id="containerPaginazione" alignment="CENTER" spacing="8">
                            <padding><Insets top="25"/></padding>
                        </HBox>

                    </children>
                </VBox>
            </children>
        </HBox>

        <!-- FOOTER (Corretto senza tag illegali) -->
        <VBox alignment="CENTER" spacing="12" style="-fx-background-color: #1B4332;">
            <padding><Insets top="35" bottom="35"/></padding>
            <children>
                <Text text="TheKnife © 2026 — Università degli Studi dell'Insubria" style="-fx-fill: #D8F3DC; -fx-font-size: 12;"/>
            </children>
        </VBox>
    </VBox>
</ScrollPane>