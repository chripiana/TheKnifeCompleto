<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>
<?import java.lang.String?>
<?import javafx.collections.FXCollections?>

<ScrollPane fitToWidth="true" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="project.demo.SearchController" stylesheets="@../style.css">

    <VBox spacing="0" styleClass="search-page">

        <HBox styleClass="navbar" alignment="CENTER_LEFT" prefHeight="64">
            <padding><Insets left="60" right="60"/></padding>
            <HBox alignment="CENTER_LEFT" onMouseClicked="#handleGoToHome" style="-fx-cursor: hand;">
                <Text text="The" style="-fx-font-family: 'Playfair Display'; -fx-font-size: 26; -fx-font-weight: bold; -fx-fill: white;"/>
                <Text text="Knife" style="-fx-font-family: 'Playfair Display'; -fx-font-size: 26; -fx-font-weight: bold; -fx-fill: #74C69D;"/>
            </HBox>

            <Region HBox.hgrow="ALWAYS" />

            <HBox spacing="15" alignment="CENTER">
                <Hyperlink text="Esci" onAction="#goToHome" styleClass="nav-link" style="-fx-text-fill: #74C69D;"/>
            </HBox>
        </HBox>

        <HBox styleClass="page-search-section" alignment="CENTER">
            <padding><Insets top="22" bottom="22" left="60" right="60"/></padding>
            <children>
                <HBox styleClass="page-search-bar" alignment="CENTER_LEFT" maxWidth="560" HBox.hgrow="ALWAYS">
                    <children>
                        <Label text="🔍" styleClass="page-search-icon"/>
                        <TextField fx:id="searchInlineField" promptText="Cerca ristoranti, cucina, città..." styleClass="page-search-input" HBox.hgrow="ALWAYS"/>
                        <Button text="Cerca" onAction="#OnCercaPremuto" styleClass="btn-search-page"/>
                    </children>
                </HBox>
            </children>
        </HBox>

        <HBox spacing="30" alignment="TOP_CENTER">
            <padding><Insets top="10" bottom="60" left="60" right="60"/></padding>
            <children>

                <VBox spacing="20" prefWidth="280" minWidth="280" styleClass="sidebar-card">
                    <padding><Insets top="30" right="25" bottom="30" left="25"/></padding>
                    <children>
                        <Label text="FILTRI RICERCA" style="-fx-text-fill: #4A6B57; -fx-font-weight: bold; -fx-letter-spacing: 1px; -fx-font-size: 12;"/>

                        <VBox spacing="5">
                            <Label text="LUOGO" styleClass="field-label"/>
                            <TextField fx:id="filterCitta" promptText="Es. Milano" styleClass="home-text-field"/>
                        </VBox>

                        <VBox spacing="5">
                            <Label text="STELLE MINIME" styleClass="field-label"/>
                            <ComboBox fx:id="filterStelle" promptText="Seleziona stelle" maxWidth="Infinity" styleClass="home-text-field">
                                <items>
                                    <FXCollections fx:factory="observableArrayList">
                                        <String fx:value="Tutti" />
                                        <String fx:value="3 ★ o più" />
                                        <String fx:value="4 ★ o più" />
                                        <String fx:value="5 ★" />
                                    </FXCollections>
                                </items>
                            </ComboBox>
                        </VBox>

                        <VBox spacing="5">
                            <Label text="PREZZO MAX (€)" styleClass="field-label"/>
                            <TextField fx:id="filterPrezzo" promptText="Es. 50" styleClass="home-text-field"/>
                        </VBox>

                        <Button text="AGGIORNA" onAction="#onAggiornaFiltriPremuto" styleClass="btn-primary" maxWidth="Infinity"/>
                        <Button text="Reimposta filtri" onAction="#onResetFiltriPremuto" styleClass="btn-reset" maxWidth="Infinity"/>
                    </children>
                </VBox>

                <VBox spacing="15" HBox.hgrow="ALWAYS" maxWidth="800">
                    <children>

                        <HBox alignment="CENTER_LEFT" styleClass="results-header">
                            <padding><Insets bottom="10"/></padding>
                            <children>
                                <Label fx:id="lblResultsCount" text="Risultati di ricerca" style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #1B4332;"/>
                                <Region HBox.hgrow="ALWAYS" />
                                <ComboBox fx:id="filterOrdine" promptText="Ordina per..." prefWidth="180" styleClass="home-text-field">
                                    <items>
                                        <FXCollections fx:factory="observableArrayList">
                                            <String fx:value="Predefinito" />
                                            <String fx:value="Prezzo: Più economico" />
                                            <String fx:value="Prezzo: Più caro" />
                                            <String fx:value="Nome: A-Z" />
                                        </FXCollections>
                                    </items>
                                </ComboBox>
                            </children>
                        </HBox>

                        <VBox fx:id="containerRisultati" spacing="15" HBox.hgrow="ALWAYS" />

                        <HBox fx:id="containerPaginazione" alignment="CENTER" spacing="8">
                            <padding><Insets top="25"/></padding>
                        </HBox>

                    </children>
                </VBox>
            </children>
        </HBox>

        <VBox alignment="CENTER" spacing="12" style="-fx-background-color: #1B4332;">
            <padding><Insets top="35" bottom="35"/></padding>
            <Text text="TheKnife © 2026 — Università degli Studi dell'Insubria" style="-fx-fill: #D8F3DC; -fx-font-size: 12;"/>
        </VBox>
    </VBox>
</ScrollPane>