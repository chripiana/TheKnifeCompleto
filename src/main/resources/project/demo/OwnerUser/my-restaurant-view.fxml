<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane styleClass="owner-dashboard-page" stylesheets="@../style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="project.demo.MyRestaurantController">

    <top>
        <HBox fx:id="hboxNavbar" alignment="CENTER_LEFT" prefHeight="64.0" spacing="16.0" styleClass="navbar">
            <padding><Insets left="24.0" right="24.0" /></padding>
            <children>
                <HBox alignment="CENTER" styleClass="logo-container" onMouseClicked="#handleGoToHome" style="-fx-cursor: hand;">
                    <children>
                        <Label fx:id="lblLogoThe" styleClass="logo-text-main" text="The" />
                        <Label fx:id="lblLogoKnife" styleClass="logo-text-sub" text="Knife" />
                    </children>
                </HBox>
                <Region HBox.hgrow="ALWAYS" />

                <Region HBox.hgrow="ALWAYS" />

                <Button fx:id="btnNuovoRistorante" text="+ Nuovo Ristorante" onAction="#handleNuovoRistorante" styleClass="btn-primary" />
                <Button fx:id="btnLogout" text="Esci" onAction="#handleLogout" styleClass="btn-outline-hero" />
            </children>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" styleClass="modern-scrollpane">
            <content>
                <VBox spacing="24.0">
                    <padding><Insets top="28.0" bottom="40.0" left="60.0" right="60.0" /></padding>
                    <children>

                        <HBox alignment="CENTER_LEFT" spacing="16.0" styleClass="hero-dash">
                            <padding><Insets top="28.0" bottom="28.0" left="32.0" right="32.0" /></padding>
                            <children>
                                <VBox spacing="4.0">
                                    <children>
                                        <Label styleClass="dash-nome" text="I Miei Ristoranti" />
                                        <Label fx:id="lblSottotitolo" styleClass="dash-badge" text="Gestisci i tuoi locali e le recensioni ricevute" />
                                    </children>
                                </VBox>
                                <Region HBox.hgrow="ALWAYS" />
                                <VBox alignment="CENTER" styleClass="kpi">
                                    <children>
                                        <Label fx:id="lblNumRistoranti" styleClass="kpi-num" text="0" />
                                        <Label styleClass="kpi-label" text="RISTORANTI" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <FlowPane fx:id="containerRistoranti" hgap="20.0" vgap="20.0" />

                        <VBox fx:id="emptyRistorantiBox" alignment="CENTER" spacing="10.0" styleClass="empty-state-box" visible="false" managed="false">
                            <padding><Insets top="50.0" bottom="50.0" /></padding>
                            <children>
                                <Label text="🍽️" style="-fx-font-size: 34px;" />
                                <Label styleClass="empty-state-title" text="Non hai ancora aggiunto nessun ristorante" />
                                <Label styleClass="empty-state-subtitle" text="Crea il tuo primo locale per iniziare a ricevere recensioni" />
                                <Button text="+ Nuovo Ristorante" onAction="#handleNuovoRistorante" styleClass="btn-accent" />
                            </children>
                        </VBox>

                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </center>

    <bottom>
        <HBox alignment="CENTER" prefHeight="48.0" styleClass="footer">
            <children>
                <Label styleClass="footer-text" text="TheKnife © 2026 — Università degli Studi dell'Insubria" />
            </children>
        </HBox>
    </bottom>
</BorderPane>
