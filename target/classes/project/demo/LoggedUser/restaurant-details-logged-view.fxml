<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane styleClass="restaurant-details-page" stylesheets="@../style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="project.demo.RestaurantDetailsController">

    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="64.0" spacing="16.0" styleClass="navbar">
            <padding><Insets left="24.0" right="24.0" /></padding>
            <children>
                <HBox alignment="CENTER" styleClass="logo-container" onMouseClicked="#handleGoToHome" style="-fx-cursor: hand;">
                    <children>
                        <Label styleClass="logo-text-main" text="The" />
                        <Label styleClass="logo-text-sub" text="Knife" />
                    </children>
                </HBox>
                <Region HBox.hgrow="ALWAYS" />

                <Label fx:id="lblBreadcrumb" styleClass="nav-breadcrumb" text="Home  ›  Esplora  ›  Dettagli" />

                <Region HBox.hgrow="ALWAYS" />

                <HBox spacing="10" alignment="CENTER">
                    <Button text="Cerca" onAction="#handleCerca" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-cursor: hand;" />
                    <Button text="Preferiti" onAction="#handlePreferiti" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-cursor: hand;" />
                    <Button text="Recensioni" onAction="#handleRecensioni" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-cursor: hand;" />
                    <Button text="Profilo" onAction="#handleProfilo" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-cursor: hand;" />
                    <Button text="Esci" onAction="#handleLogout" style="-fx-background-color: transparent; -fx-text-fill: #FF6B6B; -fx-cursor: hand;" />
                </HBox>

                <Button text="← Torna ai risultati" onAction="#handleTornaRisultati"
                        style="-fx-background-color: #40916C; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20px; -fx-padding: 8px 20px; -fx-cursor: hand; -fx-font-size: 13px;" />
            </children>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" styleClass="modern-scrollpane">
            <content>
                <VBox spacing="24.0">
                    <padding><Insets top="28.0" bottom="40.0" left="60.0" right="60.0" /></padding>
                    <children>

                        <HBox alignment="CENTER_LEFT" spacing="16.0" styleClass="owner-strip">
                            <padding><Insets top="16.0" bottom="16.0" left="20.0" right="20.0" /></padding>
                            <children>
                                <VBox alignment="CENTER" styleClass="owner-avatar">
                                    <children>
                                        <Label text="MF" styleClass="owner-avatar-text" />
                                    </children>
                                </VBox>
                                <VBox spacing="2.0">
                                    <children>
                                        <HBox alignment="CENTER_LEFT" spacing="8.0">
                                            <children>
                                                <Label fx:id="lblGestoreNome" text="Mario Ferrari" styleClass="owner-name" />
                                                <Label text="🧑‍🍳 Ristoratore" styleClass="badge-ristoratore" />
                                            </children>
                                        </HBox>
                                        <Label fx:id="lblGestoreEmail" text="✉️  mario.ferrari@theknife.it" styleClass="owner-email" />
                                    </children>
                                </VBox>
                                <Region HBox.hgrow="ALWAYS" />
                                <Label text="Titolare di questo ristorante" styleClass="owner-hint" />
                            </children>
                        </HBox>

                        <!-- Modificato: aggiunto fx:id="hboxHero" -->
                        <HBox fx:id="hboxHero" alignment="CENTER_LEFT" spacing="24.0" styleClass="hero-dash-morbida">
                            <padding><Insets top="32.0" bottom="32.0" left="32.0" right="32.0" /></padding>
                            <children>
                                <VBox alignment="CENTER" styleClass="avatar-ristorante-container">
                                    <children>
                                        <!-- Modificato: aggiunto fx:id="lblAvatarRistorante" e rimosso il testo fisso -->
                                        <Label fx:id="lblAvatarRistorante" style="-fx-font-size: 32px;" />
                                    </children>
                                </VBox>
                                <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                    <!-- ... resto del codice invariato ... -->
                                    <children>
                                        <Label fx:id="lblNomeRistorante" styleClass="dash-nome-ristorante" text="Trattoria Da Mario" />
                                        <Label fx:id="lblCitta" styleClass="hero-subtext" text="📍 Via Roma 12, Milano, Italia" />
                                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                                            <children>
                                                <Label fx:id="lblCucina" styleClass="dash-badge" text="Cucina" />
                                                <Label fx:id="lblPrezzo" styleClass="dash-badge" text="Prezzo" />
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>
                                <VBox alignment="CENTER" spacing="4.0">
                                    <children>
                                        <Label fx:id="lblRatingBigNumber" text="-" styleClass="rating-big-number" />
                                        <Label fx:id="lblStarsDisplayBig" text="☆☆☆☆☆" styleClass="stars-display-big" />
                                        <Label fx:id="lblNumRecensioniBox" text="0 recensioni" styleClass="rating-muted-sm" />

                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <GridPane hgap="24.0" vgap="24.0">
                            <columnConstraints>
                                <ColumnConstraints hgrow="ALWAYS" />
                                <ColumnConstraints minWidth="300.0" prefWidth="300.0" maxWidth="300.0" />
                            </columnConstraints>

                            <VBox spacing="20.0" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                <children>

                                    <VBox spacing="4.0" styleClass="card">
                                        <padding><Insets top="20.0" bottom="20.0" left="20.0" right="20.0" /></padding>
                                        <children>
                                            <Label styleClass="section-title" text="INFORMAZIONI GENERALI" />
                                            <VBox spacing="0.0" style="-fx-padding: 10 0 0 0;">
                                                <children>
                                                    <HBox styleClass="info-row"><children><Label styleClass="info-key" text="🏳️ Nazione" /><Region HBox.hgrow="ALWAYS" /><Label fx:id="lblNazione" styleClass="info-val" text="Italia" /></children></HBox>
                                                    <HBox styleClass="info-row"><children><Label styleClass="info-key" text="🏙️ Città" /><Region HBox.hgrow="ALWAYS" /><Label fx:id="lblCittaVal" styleClass="info-val" text="Milano" /></children></HBox>
                                                    <HBox styleClass="info-row"><children><Label styleClass="info-key" text="📌 Indirizzo" /><Region HBox.hgrow="ALWAYS" /><Label fx:id="lblIndirizzo" styleClass="info-val" text="Via Roma, 12" /></children></HBox>
                                                    <HBox styleClass="info-row"><children><Label styleClass="info-key" text="🍳 Tipologia cucina" /><Region HBox.hgrow="ALWAYS" /><Label fx:id="lblTipologiaCucinaBox" styleClass="info-val" text="Italiana" /></children></HBox>
                                                    <HBox styleClass="info-row"><children><Label styleClass="info-key" text="💰 Prezzo medio" /><Region HBox.hgrow="ALWAYS" /><Label fx:id="lblPrezzoMedioBox" styleClass="info-val-price" text="35 € a persona" /></children></HBox>
                                                </children>
                                            </VBox>
                                        </children>
                                    </VBox>

                                    <VBox spacing="12.0" styleClass="card">
                                        <padding><Insets top="20.0" bottom="20.0" left="20.0" right="20.0" /></padding>
                                        <children>
                                            <Label styleClass="section-title" text="POSIZIONE" />
                                            <VBox spacing="10.0" styleClass="mappa-box">
                                                <padding><Insets top="16.0" bottom="16.0" left="16.0" right="16.0" /></padding>
                                                <children>
                                                    <VBox alignment="CENTER" styleClass="map-visual-placeholder">
                                                        <children>
                                                            <Label text="📍" style="-fx-font-size: 30px;" />
                                                        </children>
                                                    </VBox>
                                                    <Label fx:id="lblMappaTestoIndirizzo" styleClass="map-title" text="Via Roma, 12 — Milano, Italia" />
                                                    <HBox spacing="16.0">
                                                        <children>
                                                            <Label fx:id="lblLatitudine" styleClass="map-coords" text="Lat: 45.4642°" />
                                                            <Label fx:id="lblLongitudine" styleClass="map-coords" text="Lng: 9.1900°" />
                                                        </children>
                                                    </HBox>
                                                </children>
                                            </VBox>
                                        </children>
                                    </VBox>

                                    <VBox spacing="16.0" styleClass="card">
                                        <padding><Insets top="20.0" bottom="20.0" left="20.0" right="20.0" /></padding>
                                        <children>
                                            <Label styleClass="section-title" text="VALUTAZIONI" />
                                            <HBox spacing="28.0" alignment="CENTER_LEFT">
                                                <children>
                                                    <VBox alignment="CENTER" spacing="4.0">
                                                        <children>
                                                            <Label text="4.2" styleClass="rating-big-number" />
                                                            <Label text="★★★★☆" styleClass="stars-display-big" />
                                                            <Label text="128 recensioni" styleClass="rating-muted-sm" />
                                                        </children>
                                                    </VBox>
                                                    <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                                        <children>
                                                            <HBox spacing="8.0" alignment="CENTER_LEFT">
                                                                <children>
                                                                    <Label text="5 ★" styleClass="rating-muted-sm" minWidth="30" />
                                                                    <ProgressBar fx:id="barStelle5" progress="0.0" styleClass="rating-bar" HBox.hgrow="ALWAYS" maxWidth="Infinity" />
                                                                    <Label fx:id="lblPctStelle5" text="0%" styleClass="rating-muted-sm" minWidth="36" />
                                                                </children>
                                                            </HBox>
                                                            <HBox spacing="8.0" alignment="CENTER_LEFT">
                                                                <children>
                                                                    <Label text="4 ★" styleClass="rating-muted-sm" minWidth="30" />
                                                                    <ProgressBar fx:id="barStelle4" progress="0.0" styleClass="rating-bar" HBox.hgrow="ALWAYS" maxWidth="Infinity" />
                                                                    <Label fx:id="lblPctStelle4" text="0%" styleClass="rating-muted-sm" minWidth="36" />
                                                                </children>
                                                            </HBox>
                                                            <HBox spacing="8.0" alignment="CENTER_LEFT">
                                                                <children>
                                                                    <Label text="3 ★" styleClass="rating-muted-sm" minWidth="30" />
                                                                    <ProgressBar fx:id="barStelle3" progress="0.0" styleClass="rating-bar" HBox.hgrow="ALWAYS" maxWidth="Infinity" />
                                                                    <Label fx:id="lblPctStelle3" text="0%" styleClass="rating-muted-sm" minWidth="36" />
                                                                </children>
                                                            </HBox>
                                                            <HBox spacing="8.0" alignment="CENTER_LEFT">
                                                                <children>
                                                                    <Label text="2 ★" styleClass="rating-muted-sm" minWidth="30" />
                                                                    <ProgressBar fx:id="barStelle2" progress="0.0" styleClass="rating-bar" HBox.hgrow="ALWAYS" maxWidth="Infinity" />
                                                                    <Label fx:id="lblPctStelle2" text="0%" styleClass="rating-muted-sm" minWidth="36" />
                                                                </children>
                                                            </HBox>
                                                            <HBox spacing="8.0" alignment="CENTER_LEFT">
                                                                <children>
                                                                    <Label text="1 ★" styleClass="rating-muted-sm" minWidth="30" />
                                                                    <ProgressBar fx:id="barStelle1" progress="0.0" styleClass="rating-bar" HBox.hgrow="ALWAYS" maxWidth="Infinity" />
                                                                    <Label fx:id="lblPctStelle1" text="0%" styleClass="rating-muted-sm" minWidth="36" />
                                                                </children>
                                                            </HBox>
                                                        </children>
                                                    </VBox>
                                                </children>
                                            </HBox>
                                        </children>
                                    </VBox>

                                    <VBox spacing="12.0" styleClass="card">
                                        <padding><Insets top="20.0" bottom="20.0" left="20.0" right="20.0" /></padding>
                                        <children>
                                            <Label styleClass="section-title" text="LASCIA UNA RECENSIONE" />
                                            <Label text="LA TUA VALUTAZIONE" styleClass="filter-label" />
                                            <HBox spacing="8" alignment="CENTER_LEFT">
                                                <children>
                                                    <Label fx:id="starRec1" text="★" onMouseClicked="#handleStarRec1" styleClass="star-input-icon" style="-fx-cursor: hand; -fx-font-size: 22px; -fx-text-fill: #CBD5E1;" />
                                                    <Label fx:id="starRec2" text="★" onMouseClicked="#handleStarRec2" styleClass="star-input-icon" style="-fx-cursor: hand; -fx-font-size: 22px; -fx-text-fill: #CBD5E1;" />
                                                    <Label fx:id="starRec3" text="★" onMouseClicked="#handleStarRec3" styleClass="star-input-icon" style="-fx-cursor: hand; -fx-font-size: 22px; -fx-text-fill: #CBD5E1;" />
                                                    <Label fx:id="starRec4" text="★" onMouseClicked="#handleStarRec4" styleClass="star-input-icon" style="-fx-cursor: hand; -fx-font-size: 22px; -fx-text-fill: #CBD5E1;" />
                                                    <Label fx:id="starRec5" text="★" onMouseClicked="#handleStarRec5" styleClass="star-input-icon" style="-fx-cursor: hand; -fx-font-size: 22px; -fx-text-fill: #CBD5E1;" />
                                                </children>
                                            </HBox>



                                            <TextArea fx:id="recensioneTextArea" prefRowCount="3" promptText="Com'è stato il pasto?" styleClass="modern-textarea" />
                                            <Button fx:id="btnPubblicaRecensione" text="Pubblica Recensione" onAction="#handlePubblicaRecensione" styleClass="btn-accent" />
                                        </children>
                                    </VBox>
                                </children>
                            </VBox>

                            <VBox spacing="20.0" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                <children>
                                    <VBox spacing="10.0" styleClass="card">
                                        <padding><Insets top="20.0" bottom="20.0" left="20.0" right="20.0" /></padding>
                                        <children>
                                            <Button fx:id="btnPrenotaOra" text="Prenota Ora" onAction="#handlePrenotaOra" maxWidth="Infinity" styleClass="btn-primary" />
                                            <Button fx:id="btnAggiungiPreferiti" text="♡  Aggiungi ai Preferiti" onAction="#handleTogglePreferiti" maxWidth="Infinity" styleClass="btn-outline-hero" style="-fx-text-fill: #2D6A4F; -fx-border-color: #B7E4C7;" />

                                        </children>
                                    </VBox>

                                    <VBox spacing="10.0" styleClass="card">
                                        <padding><Insets top="20.0" bottom="20.0" left="20.0" right="20.0" /></padding>
                                        <children>
                                            <Label styleClass="section-title" text="RIEPILOGO" />
                                            <VBox spacing="0.0" style="-fx-padding: 8 0 0 0;">
                                                <children>
                                                    <HBox styleClass="info-row"><children><Label styleClass="info-key" text="⭐ Media stelle" /><Region HBox.hgrow="ALWAYS" /><Label fx:id="lblRiepilogoStelle" styleClass="info-val" text="-" /></children></HBox>
                                                    <HBox styleClass="info-row"><children><Label styleClass="info-key" text="💰 Prezzo medio" /><Region HBox.hgrow="ALWAYS" /><Label fx:id="lblRiepilogoPrezzo" styleClass="info-val" text="-" /></children></HBox>
                                                    <HBox styleClass="info-row"><children><Label styleClass="info-key" text="🍳 Cucina" /><Region HBox.hgrow="ALWAYS" /><Label fx:id="lblRiepilogoCucina" styleClass="info-val" text="-" /></children></HBox>
                                                </children>
                                            </VBox>
                                        </children>
                                    </VBox>
                                </children>
                            </VBox>
                        </GridPane>
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </center>

    <bottom>
        <HBox alignment="CENTER" prefHeight="48.0" styleClass="footer">
            <children>
                <Label styleClass="footer-text" text="TheKnife © 2026 — Università degli Studi dell'Insubria" />
            </children>
        </HBox>
    </bottom>
</BorderPane>